{
  "name": "keepscape",
  "version": "0.1.0",
  "private": true,
  "description": "Turn true photos and original voice into source-grounded playable memory exhibits with GPT-5.6 and Codex.",
  "license": "MIT",
  "packageManager": "pnpm@10.26.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "voice:openai": "tsx scripts/generate-openai-narration.ts",
    "voice:openai:continuous": "tsx scripts/generate-openai-continuous-narration.ts",
    "verify:codex": "tsx scripts/verify-live-codex.ts",
    "check": "pnpm lint && pnpm typecheck && pnpm test && pnpm build",
    "cf:build": "opennextjs-cloudflare build",
    "cf:preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "cf:upload": "opennextjs-cloudflare build && opennextjs-cloudflare upload",
    "cf:deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "cf:typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts"
  },
  "dependencies": {
    "@fontsource-variable/archivo": "5.2.8",
    "@fontsource-variable/ibm-plex-sans": "5.2.8",
    "@fontsource/ibm-plex-mono": "5.2.7",
    "@openai/codex-sdk": "0.144.4",
    "@opennextjs/cloudflare": "1.20.1",
    "lucide-react": "1.24.0",
    "motion": "12.42.2",
    "next": "16.2.10",
    "openai": "6.47.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "9.39.5",
    "eslint-config-next": "16.2.10",
    "tsx": "^4.20.0",
    "typescript": "5.9.3",
    "vitest": "4.1.10",
    "wrangler": "4.110.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "unrs-resolver",
      "workerd"
    ]
  }
}
