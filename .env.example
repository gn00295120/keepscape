# Required only for live GPT-5.6 analysis. Built-in exhibits run without a key.
OPENAI_API_KEY=

# Current Build Week model target. Override only when intentionally testing another model.
OPENAI_MODEL=gpt-5.6

# Optional. Leave unset to use the Codex model supported by the signed-in account.
# CODEX_MODEL=gpt-5.3-codex

# Set to 1 only in a trusted server environment to enable live Codex exhibit generation.
KEEPSCAPE_ENABLE_CODEX=0
